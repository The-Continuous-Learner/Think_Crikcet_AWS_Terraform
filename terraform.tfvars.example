# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is git-ignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# S3 bucket where the backend CI uploads the built Spring Boot jar.
# This bucket is separate from the Terraform state bucket.
jar_s3_bucket = "your-artifact-bucket-name"

# ── Optional overrides (defaults are fine for most cases) ─────────────────────

# aws_region      = "ap-south-1"
# availability_zone = "ap-south-1a"
# instance_type   = "t3.micro"
# app_port        = 8080
# jar_s3_key      = "think-cricket/app.jar"
# ssm_prefix      = "/think-cricket"
# environment     = "prod"
